# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb://127.0.0.1:27017/debt-guidance-db

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=30d

# AI Provider Configuration
# Supported providers: 'mock', 'openai', 'gemini'
AI_PROVIDER=mock

# AI Provider Credentials (Required if using openai or gemini)
OPENAI_API_KEY=
GEMINI_API_KEY=
